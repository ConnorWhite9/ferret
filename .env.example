# Copy to .env and fill in values before training.
# Load with: set -a && source .env && set +a

# ── PyTorch ───────────────────────────────────────────────────────────────────
# Override default ~/.cache/torch (useful when home dir is not writable).
TORCH_HOME=.cache/torch

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Required if running with --track / train_full.yaml (track: true).
# Get your key from https://wandb.ai/settings
# WANDB_API_KEY=<your-key>

# Wandb project defaults (can also be set via CLI flags).
WANDB_PROJECT=ferret
# WANDB_ENTITY=<your-entity>

# ── Data paths ────────────────────────────────────────────────────────────────
# Override default data/raw and data/cache directories if needed.
# FERRET_DATA_ROOT=data/raw
# FERRET_CACHE_ROOT=data/cache

# ── Hardware ──────────────────────────────────────────────────────────────────
# Set to "0" to disable CUDA even if a GPU is present (CPU-only debug run).
# CUDA_VISIBLE_DEVICES=0
